# =========================
# LLM 配置
# =========================

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

LLM_ENABLE_QUERY_GENERATION=true
LLM_ENABLE_SOURCE_FILTER=true
LLM_ENABLE_BLOG_GENERATION=true
LLM_ENABLE_CHECK_AND_REWRITE=true

# =========================
# 搜索配置
# =========================

SEARCH_MODE=no_api
SEARCH_MAX_RESULTS_PER_QUERY=10
SEARCH_MAX_ARTICLES_PER_TOPIC=7
SEARCH_MIN_ARTICLES_PER_TOPIC=4
ENABLE_DDGS_SEARCH=true
ENABLE_SEED_SOURCE_SEARCH=true
ENABLE_MANUAL_URLS=true

# =========================
# 生成配置
# =========================

TARGET_ARTICLE_WORD_COUNT=3200
MIN_ARTICLE_WORD_COUNT=2800
MAX_ARTICLE_WORD_COUNT=3600

INCLUDE_BRAND_MESSAGE_PROBABILITY=0.6
INCLUDE_PHONE_CTA_PROBABILITY=0.5

PHONE_CTA_TEXT=致电212-899-8888，获取免费咨询！
BRAND_MESSAGE_TITLE=古灵王律师团寄语

# =========================
# 检查配置
# =========================

MAX_TEMPLATE_OVERALL_SIMILARITY=0.30
MAX_TEMPLATE_PARAGRAPH_SIMILARITY=0.60
MAX_CONTINUOUS_DUPLICATE_CHARS=30
STRUCTURE_STYLE_PASS_SCORE=75
LANGUAGE_STYLE_PASS_SCORE=75

# =========================
# 日志配置
# =========================

LOG_LEVEL=INFO
PRINT_DETAILED_LOGS=true
SAVE_LOGS=true
